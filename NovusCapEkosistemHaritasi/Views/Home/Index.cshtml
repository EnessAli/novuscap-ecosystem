@{
    ViewData["Title"] = "Ana Sayfa";
    var ecosystemPoints = ViewBag.EcosystemPoints as IEnumerable<NovusCapEkosistemHaritasi.Models.EcosystemPoint>;
    var categories = ViewBag.Categories as IEnumerable<NovusCapEkosistemHaritasi.Models.Category>;
    var cities = ViewBag.Cities as IEnumerable<string>;
}

<div class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white py-16">
    <div class="container mx-auto px-4">
        <div class="max-w-3xl">
            <h1 class="text-4xl md:text-5xl font-bold mb-4">Türkiye Teknoloji ve Eğitim Ekosistemi</h1>
            <p class="text-xl mb-8">Türkiye'deki teknoloji ve eğitim ekosistemini keşfedin. Eğitim kurumları, teknoloji merkezleri ve daha fazlası...</p>
            <div class="flex flex-wrap gap-4">
                <a href="@Url.Action("Map", "EcosystemPoints")" class="bg-white text-blue-600 hover:bg-blue-50 px-6 py-3 rounded-lg font-medium shadow-md transition-colors">
                    <i class="fas fa-map-marked-alt mr-2"></i> Haritayı Görüntüle
                </a>
                <a href="@Url.Action("Index", "EcosystemPoints")" class="bg-transparent hover:bg-blue-500 text-white border border-white px-6 py-3 rounded-lg font-medium transition-colors">
                    <i class="fas fa-list mr-2"></i> Tüm Noktaları Listele
                </a>
            </div>
            </div>
            </div>
            </div>
            
<div class="py-12 bg-white">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-800 mb-4">Ekosistem İstatistikleri</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">Türkiye'nin teknoloji ve eğitim ekosistemindeki en güncel veriler</p>
            </div>
            
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-blue-50 rounded-lg p-6 text-center shadow-md">
                <div class="text-blue-600 text-4xl mb-2">
                    <i class="fas fa-map-marker-alt"></i>
            </div>
                <div class="text-3xl font-bold text-gray-800 mb-1">@(ecosystemPoints?.Count() ?? 0)</div>
                <div class="text-gray-600">Ekosistem Noktası</div>
            </div>
            
            <div class="bg-indigo-50 rounded-lg p-6 text-center shadow-md">
                <div class="text-indigo-600 text-4xl mb-2">
                    <i class="fas fa-building"></i>
            </div>
                <div class="text-3xl font-bold text-gray-800 mb-1">@(categories?.Count() ?? 0)</div>
                <div class="text-gray-600">Kategori</div>
            </div>
            
            <div class="bg-purple-50 rounded-lg p-6 text-center shadow-md">
                <div class="text-purple-600 text-4xl mb-2">
                    <i class="fas fa-city"></i>
            </div>
                <div class="text-3xl font-bold text-gray-800 mb-1">@(cities?.Count() ?? 0)</div>
                <div class="text-gray-600">Şehir</div>
            </div>
            
            <div class="bg-green-50 rounded-lg p-6 text-center shadow-md">
                <div class="text-green-600 text-4xl mb-2">
                    <i class="fas fa-user-graduate"></i>
            </div>
                <div class="text-3xl font-bold text-gray-800 mb-1">10,000+</div>
                <div class="text-gray-600">Öğrenci</div>
            </div>
        </div>
    </div>
</div>

<div class="py-12 bg-gray-50">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-800 mb-4">Kategoriler</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">Ekosistem noktalarını kategorilere göre keşfedin</p>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @if (categories != null)
            {
                foreach (var category in categories)
                {
                    <a href="@Url.Action("Index", "EcosystemPoints", new { categoryId = category.Id })" class="bg-white rounded-lg p-6 shadow-md hover:shadow-lg transition-shadow group">
                        <div class="text-center">
                            <div class="text-blue-600 text-4xl mb-4 group-hover:text-blue-700 transition-colors">
                                <i class="@(string.IsNullOrEmpty(category.Icon) ? "fas fa-folder" : category.Icon)"></i>
                            </div>
                            <h3 class="text-xl font-semibold text-gray-800 mb-2">@category.Name</h3>
                            <p class="text-gray-600">@category.Description</p>
                        </div>
                    </a>
                }
            }
        </div>
    </div>
</div>

<div class="py-12 bg-white">
    <div class="container mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-800 mb-4">Son Eklenen Noktalar</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">Ekosisteme yeni eklenen noktaları keşfedin</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @if (ecosystemPoints != null)
            {
                foreach (var point in ecosystemPoints.Take(6))
                {
                    <div class="bg-white rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-shadow">
                        <div class="h-48 bg-gray-200 flex items-center justify-center">
                            <i class="@(string.IsNullOrEmpty(point.Icon) ? "fas fa-map-marker-alt" : point.Icon) text-4xl text-gray-400"></i>
                        </div>
                        <div class="p-6">
                            <div class="flex justify-between items-start mb-2">
                                <h3 class="text-xl font-semibold text-gray-800">@point.Name</h3>
                                <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full">@point.Category?.Name</span>
                            </div>
                            <p class="text-gray-600 mb-4 line-clamp-2">@point.Description</p>
                            <div class="flex items-center text-gray-500 mb-4">
                                <i class="fas fa-map-marker-alt mr-2"></i>
                                <span>@point.City, @point.District</span>
                            </div>
                            <a href="@Url.Action("Details", "EcosystemPoints", new { id = point.Id })" class="text-blue-600 hover:text-blue-800 font-medium">
                                Detayları Görüntüle <i class="fas fa-arrow-right ml-1"></i>
                            </a>
                        </div>
                    </div>
                }
            }
        </div>
        
        <div class="text-center mt-8">
            <a href="@Url.Action("Index", "EcosystemPoints")" class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition-colors">
                Tüm Noktaları Görüntüle
            </a>
        </div>
    </div>
</div>

<div class="py-12 bg-blue-600 text-white">
    <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl font-bold mb-6">Ekosisteme Katkıda Bulunun</h2>
            <p class="text-xl mb-8">Bildiğiniz bir ekosistem noktasını haritamıza ekleyerek platformumuza katkıda bulunabilirsiniz.</p>
            <a href="@Url.Action("Contact", "Home")" class="bg-white text-blue-600 hover:bg-blue-50 px-6 py-3 rounded-lg font-medium shadow-md transition-colors inline-block">
                İletişime Geçin
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add any custom scripts for the homepage here
    </script>
}

@section Styles {
    <style>
        /* Add any custom styles for the homepage here */
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
}