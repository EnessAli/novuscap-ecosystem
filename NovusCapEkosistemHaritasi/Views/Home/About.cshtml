@model NovusCapEkosistemHaritasi.Models.PageContent
@{
    ViewData["Title"] = ViewData["Title"] ?? "Hakkımızda";
    ViewData["Subtitle"] = ViewData["Subtitle"] ?? "Türkiye Teknoloji ve Eğitim Ekosistemi";
}

<div class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white py-16">
    <div class="container mx-auto px-4">
        <div class="max-w-3xl">
            <h1 class="text-4xl md:text-5xl font-bold mb-4">@ViewData["Title"]</h1>
            <p class="text-xl">@ViewData["Subtitle"]</p>
        </div>
    </div>
</div>

<div class="bg-white py-12">
    <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
            <div class="prose prose-lg max-w-none">
                @if (Model != null)
                {
                    @Html.Raw(Model.Content)
                }
                else
                {
                    <h2>Projemiz Hakkında</h2>
                    <p>
                        NovusCap Ekosistem Haritası, Türkiye'deki teknoloji ve eğitim ekosistemini haritalandırmak amacıyla oluşturulmuş bir platformdur. 
                        Bu platform, öğrencilere, girişimcilere ve teknoloji meraklılarına, bulundukları bölgelerdeki teknoloji ve eğitim olanaklarını 
                        keşfetmelerini sağlamayı amaçlamaktadır.
                    </p>
                    
                    <h2>Vizyonumuz</h2>
                    <p>
                        Türkiye'nin her köşesindeki teknoloji ve eğitim ekosistemini görünür kılarak, bu alandaki fırsatları herkes için erişilebilir hale getirmek.
                    </p>
                    
                    <h2>Misyonumuz</h2>
                    <p>
                        Teknoloji ve eğitim alanındaki tüm paydaşları bir araya getirerek, işbirliği ve yenilikçilik için bir platform oluşturmak. 
                        Öğrencilere, girişimcilere ve teknoloji meraklılarına, bulundukları bölgelerdeki fırsatları keşfetmeleri için kapsamlı bir harita sunmak.
                    </p>
                    
                    <h2>Katkıda Bulunun</h2>
                    <p>
                        Eğer siz de bu haritaya katkıda bulunmak istiyorsanız, lütfen bizimle iletişime geçin. Bildiğiniz bir teknoloji veya eğitim kurumunu 
                        haritamıza ekleyebilir, mevcut bilgileri güncelleyebilir veya platformun geliştirilmesine katkıda bulunabilirsiniz.
                    </p>
                }
            </div>
            
            <div class="mt-12 flex justify-center">
                <a href="@Url.Action("Contact", "Home")" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium shadow-md transition-colors">
                    <i class="fas fa-envelope mr-2"></i> Bizimle İletişime Geçin
                </a>
            </div>
        </div>
    </div>
</div>

<div class="bg-gray-50 py-12">
    <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
            <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Ekosistem Kategorilerimiz</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-white p-6 rounded-lg shadow-md text-center">
                    <div class="text-blue-600 text-4xl mb-4">
                        <i class="fas fa-school"></i>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-800 mb-2">Eğitim Kurumları</h3>
                    <p class="text-gray-600">Üniversiteler, yazılım okulları ve diğer eğitim kurumları</p>
                </div>
                
                <div class="bg-white p-6 rounded-lg shadow-md text-center">
                    <div class="text-purple-600 text-4xl mb-4">
                        <i class="fas fa-rocket"></i>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-800 mb-2">Teknoloji Merkezleri</h3>
                    <p class="text-gray-600">Teknoparklar, kuluçka merkezleri ve Ar-Ge laboratuvarları</p>
                </div>
                
                <div class="bg-white p-6 rounded-lg shadow-md text-center">
                    <div class="text-green-600 text-4xl mb-4">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-800 mb-2">Topluluklar</h3>
                    <p class="text-gray-600">Teknoloji toplulukları, kulüpler ve etkinlik grupları</p>
                </div>
                
                <div class="bg-white p-6 rounded-lg shadow-md text-center">
                    <div class="text-red-600 text-4xl mb-4">
                        <i class="fas fa-building"></i>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-800 mb-2">Şirketler</h3>
                    <p class="text-gray-600">Teknoloji şirketleri, startuplar ve yatırımcılar</p>
                </div>
            </div>
        </div>
    </div>
</div> 